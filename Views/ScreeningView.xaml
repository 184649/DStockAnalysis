<UserControl x:Class="DStockAnalysis.Views.ScreeningView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:DStockAnalysis.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:ScreeningViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="288"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ===== 左: 条件パネル ===== -->
        <Border Grid.Column="0" Style="{StaticResource Panel}" Margin="2">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="条件指定" Style="{StaticResource H2}" Margin="10,8"/>
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="10,0,10,6">
                    <Button Content="絞り込み" Command="{Binding ApplyCommand}" Width="110" Margin="0,0,6,0"/>
                    <Button Content="クリア" Command="{Binding ClearCommand}" Width="80"/>
                </StackPanel>
                <TextBlock DockPanel.Dock="Top" Text="{Binding ResultText}" Style="{StaticResource Sub}" Margin="12,0,0,4"/>

                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="10,0,10,12">

                        <TextBlock Text="業種" Style="{StaticResource FieldLabel}"/>
                        <ComboBox ItemsSource="{Binding Sectors}" SelectedItem="{Binding Criteria.Sector, Mode=TwoWay}"/>

                        <TextBlock Text="市場" Style="{StaticResource FieldLabel}"/>
                        <WrapPanel>
                            <ToggleButton Style="{StaticResource FilterToggle}" Content="東証" Width="58" IsChecked="{Binding MarketTSE, Mode=TwoWay}"/>
                            <ToggleButton Style="{StaticResource FilterToggle}" Content="東証GR" Width="58" IsChecked="{Binding MarketGR, Mode=TwoWay}"/>
                            <ToggleButton Style="{StaticResource FilterToggle}" Content="東証PR" Width="58" IsChecked="{Binding MarketPR, Mode=TwoWay}"/>
                            <ToggleButton Style="{StaticResource FilterToggle}" Content="東証ST" Width="58" IsChecked="{Binding MarketST, Mode=TwoWay}"/>
                        </WrapPanel>

                        <TextBlock Text="規模" Style="{StaticResource FieldLabel}"/>
                        <WrapPanel>
                            <ToggleButton Style="{StaticResource FilterToggle}" Content="小型" Width="58" IsChecked="{Binding ScaleSmall, Mode=TwoWay}"/>
                            <ToggleButton Style="{StaticResource FilterToggle}" Content="大型" Width="58" IsChecked="{Binding ScaleLarge, Mode=TwoWay}"/>
                            <ToggleButton Style="{StaticResource FilterToggle}" Content="中型" Width="58" IsChecked="{Binding ScaleMid, Mode=TwoWay}"/>
                        </WrapPanel>

                        <TextBlock Text="配当・還元フラグ" Style="{StaticResource FieldLabel}"/>
                        <WrapPanel>
                            <ToggleButton Style="{StaticResource FilterToggle}" Content="減配なし" Width="80" IsChecked="{Binding NoDividendCut, Mode=TwoWay}"/>
                            <ToggleButton Style="{StaticResource FilterToggle}" Content="株主優待" Width="80" IsChecked="{Binding BenefitFlag, Mode=TwoWay}"/>
                            <ToggleButton Style="{StaticResource FilterToggle}" Content="累進配当" Width="80" IsChecked="{Binding CumulativeFlag, Mode=TwoWay}"/>
                            <ToggleButton Style="{StaticResource FilterToggle}" Content="DOE採用" Width="80" IsChecked="{Binding DoeFlag, Mode=TwoWay}"/>
                        </WrapPanel>

                        <Separator Margin="0,8" Background="{StaticResource GridLineBrush}"/>
                        <TextBlock Text="株主優待" Style="{StaticResource H2}" FontSize="12" Margin="0,0,0,4"/>
                        <CheckBox Content="株主優待ありのみ" IsChecked="{Binding Criteria.BenefitOnly, Mode=TwoWay}"/>
                        <CheckBox Content="長期保有優遇ありのみ" IsChecked="{Binding Criteria.LongTermBenefitOnly, Mode=TwoWay}"/>
                        <CheckBox Content="優待廃止リスクメモあり" IsChecked="{Binding Criteria.HasBenefitRiskMemo, Mode=TwoWay}"/>

                        <TextBlock Text="優待カテゴリ" Style="{StaticResource FieldLabel}"/>
                        <ComboBox ItemsSource="{Binding BenefitCategories}" SelectedItem="{Binding Criteria.BenefitCategory, Mode=TwoWay}"/>

                        <TextBlock Text="優待権利確定月" Style="{StaticResource FieldLabel}"/>
                        <ComboBox ItemsSource="{Binding BenefitMonths}" SelectedItem="{Binding Criteria.BenefitRightsMonth, Mode=TwoWay}"/>

                        <Separator Margin="0,8" Background="{StaticResource GridLineBrush}"/>
                        <TextBlock Text="数値条件 (最小 〜 最大)" Style="{StaticResource H2}" FontSize="12" Margin="0,0,0,2"/>

                        <ItemsControl>
                            <!-- 各レンジ条件: ラベル + 最小/最大 -->
                            <ContentControl>
                                <StackPanel>
                                    <TextBlock Text="時価総額(百万円)" Style="{StaticResource FieldLabel}"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="14"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" Text="{Binding Criteria.MarketCap.Min, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"/>
                                        <TextBlock Grid.Column="1" Text="〜" HorizontalAlignment="Center"/>
                                        <TextBox Grid.Column="2" Text="{Binding Criteria.MarketCap.Max, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"/>
                                    </Grid>
                                </StackPanel>
                            </ContentControl>
                        </ItemsControl>

                        <!-- 以降は同形の RangeRow を列挙 -->
                        <StackPanel>
                            <TextBlock Text="株価(円)" Style="{StaticResource FieldLabel}"/>
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="14"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding Criteria.Price.Min, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Grid.Column="1" Text="〜" HorizontalAlignment="Center"/>
                                <TextBox Grid.Column="2" Text="{Binding Criteria.Price.Max, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"/></Grid>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="PER(倍)" Style="{StaticResource FieldLabel}"/>
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="14"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding Criteria.PER.Min, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Grid.Column="1" Text="〜" HorizontalAlignment="Center"/>
                                <TextBox Grid.Column="2" Text="{Binding Criteria.PER.Max, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"/></Grid>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="PBR(倍)" Style="{StaticResource FieldLabel}"/>
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="14"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding Criteria.PBR.Min, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Grid.Column="1" Text="〜" HorizontalAlignment="Center"/>
                                <TextBox Grid.Column="2" Text="{Binding Criteria.PBR.Max, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"/></Grid>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="ROE(%)" Style="{StaticResource FieldLabel}"/>
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="14"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding Criteria.ROE.Min, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Grid.Column="1" Text="〜" HorizontalAlignment="Center"/>
                                <TextBox Grid.Column="2" Text="{Binding Criteria.ROE.Max, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"/></Grid>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="配当利回り(%)" Style="{StaticResource FieldLabel}"/>
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="14"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding Criteria.DividendYield.Min, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Grid.Column="1" Text="〜" HorizontalAlignment="Center"/>
                                <TextBox Grid.Column="2" Text="{Binding Criteria.DividendYield.Max, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"/></Grid>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="配当性向(%)" Style="{StaticResource FieldLabel}"/>
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="14"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding Criteria.PayoutRatio.Min, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Grid.Column="1" Text="〜" HorizontalAlignment="Center"/>
                                <TextBox Grid.Column="2" Text="{Binding Criteria.PayoutRatio.Max, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"/></Grid>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="連続増配年数" Style="{StaticResource FieldLabel}"/>
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="14"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding Criteria.ConsecutiveDividendYears.Min, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Grid.Column="1" Text="〜" HorizontalAlignment="Center"/>
                                <TextBox Grid.Column="2" Text="{Binding Criteria.ConsecutiveDividendYears.Max, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"/></Grid>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="自己資本比率(%)" Style="{StaticResource FieldLabel}"/>
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="14"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding Criteria.EquityRatio.Min, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Grid.Column="1" Text="〜" HorizontalAlignment="Center"/>
                                <TextBox Grid.Column="2" Text="{Binding Criteria.EquityRatio.Max, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"/></Grid>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="有利子負債比率(%)" Style="{StaticResource FieldLabel}"/>
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="14"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding Criteria.InterestBearingDebtRatio.Min, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Grid.Column="1" Text="〜" HorizontalAlignment="Center"/>
                                <TextBox Grid.Column="2" Text="{Binding Criteria.InterestBearingDebtRatio.Max, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"/></Grid>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="増収率 1年(%)" Style="{StaticResource FieldLabel}"/>
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="14"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding Criteria.RevenueGrowth1Y.Min, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Grid.Column="1" Text="〜" HorizontalAlignment="Center"/>
                                <TextBox Grid.Column="2" Text="{Binding Criteria.RevenueGrowth1Y.Max, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"/></Grid>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="増収率 3年(%)" Style="{StaticResource FieldLabel}"/>
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="14"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding Criteria.RevenueGrowth3Y.Min, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Grid.Column="1" Text="〜" HorizontalAlignment="Center"/>
                                <TextBox Grid.Column="2" Text="{Binding Criteria.RevenueGrowth3Y.Max, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"/></Grid>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="増収率 5年(%)" Style="{StaticResource FieldLabel}"/>
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="14"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding Criteria.RevenueGrowth5Y.Min, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Grid.Column="1" Text="〜" HorizontalAlignment="Center"/>
                                <TextBox Grid.Column="2" Text="{Binding Criteria.RevenueGrowth5Y.Max, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"/></Grid>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="増収率 10年(%)" Style="{StaticResource FieldLabel}"/>
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="14"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding Criteria.RevenueGrowth10Y.Min, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Grid.Column="1" Text="〜" HorizontalAlignment="Center"/>
                                <TextBox Grid.Column="2" Text="{Binding Criteria.RevenueGrowth10Y.Max, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"/></Grid>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="営業CFマージン(%)" Style="{StaticResource FieldLabel}"/>
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="14"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding Criteria.OperatingCashFlowMargin.Min, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Grid.Column="1" Text="〜" HorizontalAlignment="Center"/>
                                <TextBox Grid.Column="2" Text="{Binding Criteria.OperatingCashFlowMargin.Max, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"/></Grid>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="営業利益率(%)" Style="{StaticResource FieldLabel}"/>
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="14"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding Criteria.OperatingMargin.Min, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Grid.Column="1" Text="〜" HorizontalAlignment="Center"/>
                                <TextBox Grid.Column="2" Text="{Binding Criteria.OperatingMargin.Max, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"/></Grid>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="純利益率(%)" Style="{StaticResource FieldLabel}"/>
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="14"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding Criteria.NetProfitMargin.Min, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Grid.Column="1" Text="〜" HorizontalAlignment="Center"/>
                                <TextBox Grid.Column="2" Text="{Binding Criteria.NetProfitMargin.Max, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"/></Grid>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="EPS" Style="{StaticResource FieldLabel}"/>
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="14"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding Criteria.EPS.Min, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Grid.Column="1" Text="〜" HorizontalAlignment="Center"/>
                                <TextBox Grid.Column="2" Text="{Binding Criteria.EPS.Max, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"/></Grid>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="売上高成長率(%)" Style="{StaticResource FieldLabel}"/>
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="14"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding Criteria.RevenueGrowthRate.Min, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Grid.Column="1" Text="〜" HorizontalAlignment="Center"/>
                                <TextBox Grid.Column="2" Text="{Binding Criteria.RevenueGrowthRate.Max, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"/></Grid>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="過去3年平均売上高成長率(%)" Style="{StaticResource FieldLabel}"/>
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="14"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding Criteria.AverageRevenueGrowth3Y.Min, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Grid.Column="1" Text="〜" HorizontalAlignment="Center"/>
                                <TextBox Grid.Column="2" Text="{Binding Criteria.AverageRevenueGrowth3Y.Max, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"/></Grid>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="営業利益成長率(%)" Style="{StaticResource FieldLabel}"/>
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="14"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding Criteria.OperatingProfitGrowthRate.Min, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Grid.Column="1" Text="〜" HorizontalAlignment="Center"/>
                                <TextBox Grid.Column="2" Text="{Binding Criteria.OperatingProfitGrowthRate.Max, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"/></Grid>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="経常利益成長率(%)" Style="{StaticResource FieldLabel}"/>
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="14"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding Criteria.OrdinaryProfitGrowthRate.Min, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Grid.Column="1" Text="〜" HorizontalAlignment="Center"/>
                                <TextBox Grid.Column="2" Text="{Binding Criteria.OrdinaryProfitGrowthRate.Max, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"/></Grid>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="純利益成長率(%)" Style="{StaticResource FieldLabel}"/>
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="14"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding Criteria.NetProfitGrowthRate.Min, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Grid.Column="1" Text="〜" HorizontalAlignment="Center"/>
                                <TextBox Grid.Column="2" Text="{Binding Criteria.NetProfitGrowthRate.Max, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"/></Grid>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="直近3ヶ月株価変化率(%)" Style="{StaticResource FieldLabel}"/>
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="14"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding Criteria.StockPriceChange3M.Min, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Grid.Column="1" Text="〜" HorizontalAlignment="Center"/>
                                <TextBox Grid.Column="2" Text="{Binding Criteria.StockPriceChange3M.Max, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"/></Grid>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="直近3ヶ月平均株価変化率(%)" Style="{StaticResource FieldLabel}"/>
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="14"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding Criteria.AverageStockPriceChange3M.Min, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Grid.Column="1" Text="〜" HorizontalAlignment="Center"/>
                                <TextBox Grid.Column="2" Text="{Binding Criteria.AverageStockPriceChange3M.Max, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"/></Grid>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="優待利回り(%)" Style="{StaticResource FieldLabel}"/>
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="14"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding Criteria.BenefitYield.Min, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Grid.Column="1" Text="〜" HorizontalAlignment="Center"/>
                                <TextBox Grid.Column="2" Text="{Binding Criteria.BenefitYield.Max, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"/></Grid>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="総合利回り(%)" Style="{StaticResource FieldLabel}"/>
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="14"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding Criteria.TotalYield.Min, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Grid.Column="1" Text="〜" HorizontalAlignment="Center"/>
                                <TextBox Grid.Column="2" Text="{Binding Criteria.TotalYield.Max, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"/></Grid>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="必要株数" Style="{StaticResource FieldLabel}"/>
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="14"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding Criteria.RequiredShares.Min, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Grid.Column="1" Text="〜" HorizontalAlignment="Center"/>
                                <TextBox Grid.Column="2" Text="{Binding Criteria.RequiredShares.Max, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"/></Grid>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="バフェットスコア" Style="{StaticResource FieldLabel}"/>
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="14"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding Criteria.BuffettScore.Min, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Grid.Column="1" Text="〜" HorizontalAlignment="Center"/>
                                <TextBox Grid.Column="2" Text="{Binding Criteria.BuffettScore.Max, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"/></Grid>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ===== 右: プリセット + 一覧 ===== -->
        <DockPanel Grid.Column="1" Margin="2">

            <!-- プリセットボタン -->
            <Border DockPanel.Dock="Top" Style="{StaticResource Panel}" Margin="0,0,0,4" Padding="8">
                <StackPanel>
                    <TextBlock Text="プリセット条件" Style="{StaticResource Sub}" Margin="2,0,0,6"/>
                    <ItemsControl ItemsSource="{Binding Presets}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Style="{StaticResource PresetButton}"
                                        Content="{Binding Name}"
                                        Command="{Binding DataContext.ApplyPresetCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- 一覧上のツールバー -->
            <Border DockPanel.Dock="Top" Background="Transparent" Margin="0,0,0,4">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="銘柄一覧" Style="{StaticResource H2}" Margin="2,0,12,0"/>
                    <Button Content="個別分析を開く" Command="{Binding OpenAnalysisCommand}" CommandParameter="{Binding SelectedStock}" Margin="0,0,6,0"/>
                    <Button Content="比較に追加" Command="{Binding AddToComparisonCommand}" CommandParameter="{Binding SelectedStock}"/>
                    <TextBlock Text="（行をダブルクリックで個別分析へ）" Style="{StaticResource Sub}" Margin="12,0,0,0"/>
                </StackPanel>
            </Border>

            <!-- 一覧テーブル -->
            <DataGrid x:Name="grid" ItemsSource="{Binding FilteredStocks}"
                      SelectedItem="{Binding SelectedStock, Mode=TwoWay}"
                      FrozenColumnCount="2"
                      HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <DataGrid.InputBindings>
                    <MouseBinding MouseAction="LeftDoubleClick"
                                  Command="{Binding OpenAnalysisCommand}"
                                  CommandParameter="{Binding SelectedStock}"/>
                </DataGrid.InputBindings>
                <DataGrid.Columns>
                    <!-- ===== 基本情報 ===== -->
                    <DataGridTextColumn Header="コード" Binding="{Binding Code}" Width="62"/>
                    <DataGridTextColumn Header="銘柄名" Binding="{Binding Name}" Width="140"/>
                    <DataGridTextColumn Header="業種" Binding="{Binding Sector}" Width="100"/>
                    <DataGridTextColumn Header="市場" Binding="{Binding Market}" Width="90"/>
                    <DataGridTextColumn Header="規模" Binding="{Binding Scale}" Width="50"/>
                    <DataGridTextColumn Header="テーマ" Binding="{Binding Theme}" Width="120"/>
                    <DataGridTextColumn Header="決算月" Binding="{Binding FiscalMonth}" Width="55" ElementStyle="{StaticResource CenterCell}"/>

                    <!-- ===== バリュエーション ===== -->
                    <DataGridTextColumn Header="時価総額" Binding="{Binding MarketCap, StringFormat=N0}" Width="90" ElementStyle="{StaticResource NumCell}"/>
                    <DataGridTextColumn Header="株価" Binding="{Binding Price, StringFormat=N0}" Width="72" ElementStyle="{StaticResource NumCell}"/>
                    <DataGridTextColumn Header="PER" Binding="{Binding PER, StringFormat=0.0}" Width="56" ElementStyle="{StaticResource NumCell}">
                        <DataGridTextColumn.CellStyle><Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}"><Setter Property="Background" Value="{Binding PER, Converter={StaticResource MetricBg}, ConverterParameter=per}"/></Style></DataGridTextColumn.CellStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="PBR" Binding="{Binding PBR, StringFormat=0.00}" Width="56" ElementStyle="{StaticResource NumCell}">
                        <DataGridTextColumn.CellStyle><Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}"><Setter Property="Background" Value="{Binding PBR, Converter={StaticResource MetricBg}, ConverterParameter=pbr}"/></Style></DataGridTextColumn.CellStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="ROE" Binding="{Binding ROE, StringFormat=0.0}" Width="56" ElementStyle="{StaticResource NumCell}">
                        <DataGridTextColumn.CellStyle><Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}"><Setter Property="Background" Value="{Binding ROE, Converter={StaticResource MetricBg}, ConverterParameter=roe}"/></Style></DataGridTextColumn.CellStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="MIX係数" Binding="{Binding MixFactor, StringFormat=0.0}" Width="64" ElementStyle="{StaticResource NumCell}">
                        <DataGridTextColumn.CellStyle><Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}"><Setter Property="Background" Value="{Binding MixFactor, Converter={StaticResource MetricBg}, ConverterParameter=mix}"/></Style></DataGridTextColumn.CellStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="EPS" Binding="{Binding EPS, StringFormat=0.0}" Width="64" ElementStyle="{StaticResource NumCell}"/>
                    <DataGridTextColumn Header="BPS" Binding="{Binding BPS, StringFormat=N0}" Width="64" ElementStyle="{StaticResource NumCell}"/>
                    <DataGridTextColumn Header="営業利益率" Binding="{Binding OperatingMargin, StringFormat=0.0}" Width="72" ElementStyle="{StaticResource NumCell}">
