<UserControl x:Class="DStockAnalysis.Views.ComparisonView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:DStockAnalysis.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DataContext="{d:DesignInstance Type=vm:ComparisonViewModel}"
             mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ===== 左: 銘柄選択 ===== -->
        <Border Grid.Column="0" Style="{StaticResource Panel}" Margin="2">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="銘柄" Style="{StaticResource H2}" Margin="10,8,10,4"/>
                <TextBox DockPanel.Dock="Top" Margin="10,0,10,4"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                <Button DockPanel.Dock="Top" Content="選択銘柄を比較に追加" Margin="10,0,10,6"
                        Command="{Binding AddCommand}" CommandParameter="{Binding PickStock}"/>
                <ListBox ItemsSource="{Binding AvailableStocks}" SelectedItem="{Binding PickStock, Mode=TwoWay}"
                         Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextBrush}">
                    <ListBox.InputBindings>
                        <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding AddCommand}" CommandParameter="{Binding PickStock}"/>
                    </ListBox.InputBindings>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="8,4"/>
                            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{StaticResource AccentDarkBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Code}" FontWeight="Bold" Width="48"/>
                                <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- ===== 右: 比較 ===== -->
        <DockPanel Grid.Column="1" Margin="2">

            <!-- 比較対象チップ -->
            <Border DockPanel.Dock="Top" Style="{StaticResource Panel}" Padding="8" Margin="0,0,0,4">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="比較対象銘柄" Style="{StaticResource H2}" Margin="0,0,12,0"/>
                        <TextBlock Text="{Binding Info}" Style="{StaticResource Sub}"/>
                        <Button Content="全てクリア" Command="{Binding ClearCommand}" Margin="12,0,0,0" Padding="8,2"/>
                    </StackPanel>
                    <ItemsControl ItemsSource="{Binding Selected}">
                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource AccentDarkBrush}" CornerRadius="14" Padding="10,4" Margin="0,0,6,4">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Code}" FontWeight="Bold" Margin="0,0,4,0"/>
                                        <TextBlock Text="{Binding Name}" Margin="0,0,8,0"/>
                                        <Button Content="✕" Padding="4,0" FontSize="10"
                                                Command="{Binding DataContext.RemoveCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- 下部: 比較グラフ -->
            <Border DockPanel.Dock="Bottom" Style="{StaticResource Panel}" Padding="6" Margin="0,4,0,0" MaxHeight="260">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="比較グラフ(スコア / 業績・規模 / 財務 / 配当・還元)" Style="{StaticResource H2}" FontSize="13" Margin="2,0,0,4"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Charts}">
                            <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- 中央: 比較テーブル(銘柄を行に並べる) -->
            <DataGrid ItemsSource="{Binding Selected}" FrozenColumnCount="2"
                      HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="" Width="34">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="✕" Padding="2,0" FontSize="10"
                                        Command="{Binding DataContext.RemoveCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="コード" Binding="{Binding Code}" Width="62"/>
                    <DataGridTextColumn Header="銘柄名" Binding="{Binding Name}" Width="140"/>
                    <DataGridTextColumn Header="業種" Binding="{Binding Sector}" Width="100"/>
                    <DataGridTextColumn Header="市場" Binding="{Binding Market}" Width="90"/>
                    <DataGridTextColumn Header="規模" Binding="{Binding Scale}" Width="50"/>
                    <DataGridTextColumn Header="時価総額" Binding="{Binding MarketCap, StringFormat=N0}" Width="90" ElementStyle="{StaticResource NumCell}"/>
                    <DataGridTextColumn Header="株価" Binding="{Binding Price, StringFormat=N0}" Width="72" ElementStyle="{StaticResource NumCell}"/>
                    <DataGridTextColumn Header="PER" Binding="{Binding PER, StringFormat=0.0}" Width="56" ElementStyle="{StaticResource NumCell}">
                        <DataGridTextColumn.CellStyle><Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}"><Setter Property="Background" Value="{Binding PER, Converter={StaticResource MetricBg}, ConverterParameter=per}"/></Style></DataGridTextColumn.CellStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="PBR" Binding="{Binding PBR, StringFormat=0.00}" Width="56" ElementStyle="{StaticResource NumCell}">
                        <DataGridTextColumn.CellStyle><Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}"><Setter Property="Background" Value="{Binding PBR, Converter={StaticResource MetricBg}, ConverterParameter=pbr}"/></Style></DataGridTextColumn.CellStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="ROE" Binding="{Binding ROE, StringFormat=0.0}" Width="56" ElementStyle="{StaticResource NumCell}">
                        <DataGridTextColumn.CellStyle><Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}"><Setter Property="Background" Value="{Binding ROE, Converter={StaticResource MetricBg}, ConverterParameter=roe}"/></Style></DataGridTextColumn.CellStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="MIX係数" Binding="{Binding MixFactor, StringFormat=0.0}" Width="64" ElementStyle="{StaticResource NumCell}">
                        <DataGridTextColumn.CellStyle><Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}"><Setter Property="Background" Value="{Binding MixFactor, Converter={StaticResource MetricBg}, ConverterParameter=mix}"/></Style></DataGridTextColumn.CellStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="配当利回り" Binding="{Binding DividendYield, StringFormat=0.00}" Width="72" ElementStyle="{StaticResource NumCell}">
                        <DataGridTextColumn.CellStyle><Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}"><Setter Property="Background" Value="{Binding DividendYield, Converter={StaticResource MetricBg}, ConverterParameter=dy}"/></Style></DataGridTextColumn.CellStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="配当性向" Binding="{Binding PayoutRatio, StringFormat=0.0}" Width="66" ElementStyle="{StaticResource NumCell}">
                        <DataGridTextColumn.CellStyle><Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}"><Setter Property="Background" Value="{Binding PayoutRatio, Converter={StaticResource MetricBg}, ConverterParameter=payout}"/></Style></DataGridTextColumn.CellStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="自己資本比率" Binding="{Binding EquityRatio, StringFormat=0.0}" Width="84" ElementStyle="{StaticResource NumCell}">
                        <DataGridTextColumn.CellStyle><Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}"><Setter Property="Background" Value="{Binding EquityRatio, Converter={StaticResource MetricBg}, ConverterParameter=equity}"/></Style></DataGridTextColumn.CellStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="有利子負債比率" Binding="{Binding InterestBearingDebtRatio, StringFormat=0.0}" Width="92" ElementStyle="{StaticResource NumCell}">
                        <DataGridTextColumn.CellStyle><Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}"><Setter Property="Background" Value="{Binding InterestBearingDebtRatio, Converter={StaticResource MetricBg}, ConverterParameter=debt}"/></Style></DataGridTextColumn.CellStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="増収率3年" Binding="{Binding RevenueGrowth3Y, StringFormat=0.0}" Width="68" ElementStyle="{StaticResource NumCell}">
                        <DataGridTextColumn.CellStyle><Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}"><Setter Property="Background" Value="{Binding RevenueGrowth3Y, Converter={StaticResource MetricBg}, ConverterParameter=growth}"/></Style></DataGridTextColumn.CellStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="営業利益率" Binding="{Binding OperatingMargin, StringFormat=0.0}" Width="72" ElementStyle="{StaticResource NumCell}">
                        <DataGridTextColumn.CellStyle><Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}"><Setter Property="Background" Value="{Binding OperatingMargin, Converter={StaticResource MetricBg}, ConverterParameter=margin}"/></Style></DataGridTextColumn.CellStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="純利益率" Binding="{Binding NetProfitMargin, StringFormat=0.0}" Width="68" ElementStyle="{StaticResource NumCell}">
                        <DataGridTextColumn.CellStyle><Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}"><Setter Property="Background" Value="{Binding NetProfitMargin, Converter={StaticResource MetricBg}, ConverterParameter=margin}"/></Style></DataGridTextColumn.CellStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="営業CF" Binding="{Binding OperatingCF, StringFormat=N0}" Width="84" ElementStyle="{StaticResource NumCell}">
                        <DataGridTextColumn.CellStyle><Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}"><Setter Property="Background" Value="{Binding OperatingCF, Converter={StaticResource MetricBg}, ConverterParameter=cf}"/></Style></DataGridTextColumn.CellStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="フリーCF" Binding="{Binding FreeCashFlow, StringFormat=N0}" Width="84" ElementStyle="{StaticResource NumCell}">
                        <DataGridTextColumn.CellStyle><Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}"><Setter Property="Background" Value="{Binding FreeCashFlow, Converter={StaticResource MetricBg}, ConverterParameter=cf}"/></Style></DataGridTextColumn.CellStyle>
                    </DataGridTextColumn>
                    <DataGridTemplateColumn Header="株主優待" Width="64">
                        <DataGridTemplateColumn.CellTemplate><DataTemplate><TextBlock Text="{Binding HasShareholderBenefit, Converter={StaticResource BoolFlag}}" Foreground="{Binding HasShareholderBenefit, Converter={StaticResource FlagBrush}}" TextAlignment="Center"/></DataTemplate></DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="優待利回り" Binding="{Binding BenefitYield, StringFormat=0.00}" Width="72" ElementStyle="{StaticResource NumCell}">
                        <DataGridTextColumn.CellStyle><Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}"><Setter Property="Background" Value="{Binding BenefitYield, Converter={StaticResource MetricBg}, ConverterParameter=benefityield}"/></Style></DataGridTextColumn.CellStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="総合利回り" Binding="{Binding TotalYield, StringFormat=0.00}" Width="74" ElementStyle="{StaticResource NumCell}">
                        <DataGridTextColumn.CellStyle><Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}"><Setter Property="Background" Value="{Binding TotalYield, Converter={StaticResource MetricBg}, ConverterParameter=totalyield}"/></Style></DataGridTextColumn.CellStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="長期適性スコア" Binding="{Binding LongTermScore, StringFormat=0}" Width="92" ElementStyle="{StaticResource NumCell}">
                        <DataGridTextColumn.CellStyle><Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}"><Setter Property="Background" Value="{Binding LongTermScore, Converter={StaticResource MetricBg}, ConverterParameter=score}"/></Style></DataGridTextColumn.CellStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="再評価期待スコア" Binding="{Binding RevaluationScore, StringFormat=0}" Width="100" ElementStyle="{StaticResource NumCell}">
                        <DataGridTextColumn.CellStyle><Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}"><Setter Property="Background" Value="{Binding RevaluationScore, Converter={StaticResource MetricBg}, ConverterParameter=score}"/></Style></DataGridTextColumn.CellStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="バフェットスコア" Binding="{Binding BuffettScore, StringFormat=0}" Width="100" FontWeight="Bold" ElementStyle="{StaticResource NumCell}">
                        <DataGridTextColumn.CellStyle><Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}"><Setter Property="Background" Value="{Binding BuffettScore, Converter={StaticResource MetricBg}, ConverterParameter=buffett}"/></Style></DataGridTextColumn.CellStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="買いたい度スコア" Binding="{Binding WantToBuyScore, StringFormat=0}" Width="100" ElementStyle="{StaticResource NumCell}">
                        <DataGridTextColumn.CellStyle><Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}"><Setter Property="Background" Value="{Binding WantToBuyScore, Converter={StaticResource MetricBg}, ConverterParameter=score}"/></Style></DataGridTextColumn.CellStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="総合判定" Binding="{Binding JudgementText}" Width="130" ElementStyle="{StaticResource CenterCell}"/>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </Grid>
</UserControl>
