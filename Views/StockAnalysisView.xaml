<UserControl x:Class="DStockAnalysis.Views.StockAnalysisView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:DStockAnalysis.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DataContext="{d:DesignInstance Type=vm:StockAnalysisViewModel}"
             mc:Ignorable="d">

    <UserControl.Resources>
        <!-- 指標カード(汎用) -->
        <Style x:Key="MetricCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Width" Value="124"/>
            <Setter Property="Height" Value="72"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="10,6"/>
        </Style>
        <Style x:Key="CardLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource SubTextBrush}"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style x:Key="CardValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ===== 左: 銘柄リスト ===== -->
        <Border Grid.Column="0" Style="{StaticResource Panel}" Margin="2">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="銘柄リスト" Style="{StaticResource H2}" Margin="10,8,10,4"/>
                <TextBox DockPanel.Dock="Top" Margin="10,0,10,6"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Tag="検索 (コード/銘柄名)"/>
                <ListBox ItemsSource="{Binding StockList}" SelectedItem="{Binding SelectedStock, Mode=TwoWay}"
                         Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextBrush}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="8,5"/>
                            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{StaticResource AccentDarkBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Code}" FontWeight="Bold" Width="48"/>
                                    <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="バフェット " Style="{StaticResource Sub}"/>
                                    <TextBlock Text="{Binding BuffettScore, StringFormat=0}" Style="{StaticResource Sub}"
                                               Foreground="{Binding BuffettScore, Converter={StaticResource ScoreSolid}, ConverterParameter=buffett}"/>
                                    <TextBlock Text="{Binding JudgementText, StringFormat=' / {0}'}" Style="{StaticResource Sub}"/>
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- ===== 右: 詳細 ===== -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Margin="2">
            <Grid>
                <!-- 未選択時 -->
                <TextBlock Text="左のリストから銘柄を選択してください。" Style="{StaticResource Sub}"
                           HorizontalAlignment="Center" Margin="0,40"
                           Visibility="{Binding HasSelection, Converter={StaticResource BoolVis}, ConverterParameter=invert}"/>

                <StackPanel Visibility="{Binding HasSelection, Converter={StaticResource BoolVis}}">

                    <!-- ===== ヘッダー ===== -->
                    <Border Style="{StaticResource Card}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding SelectedStock.Code}" Style="{StaticResource H1}" Margin="0,0,10,0"/>
                                    <TextBlock Text="{Binding SelectedStock.Name}" Style="{StaticResource H1}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Text="{Binding SelectedStock.Market}" Style="{StaticResource Sub}" Margin="0,0,12,0"/>
                                    <TextBlock Text="{Binding SelectedStock.Sector}" Style="{StaticResource Sub}" Margin="0,0,12,0"/>
                                    <TextBlock Text="{Binding SelectedStock.FiscalMonth, StringFormat=決算月: {0}}" Style="{StaticResource Sub}" Margin="0,0,12,0"/>
                                    <TextBlock Text="{Binding SelectedStock.DataUpdated, StringFormat=データ更新日: {0:yyyy/MM/dd}}" Style="{StaticResource Sub}"/>
                                </StackPanel>
                                <TextBlock Text="{Binding SelectedStock.Description}" Style="{StaticResource Sub}"
                                           TextWrapping="Wrap" Margin="0,6,0,0" MaxWidth="900" HorizontalAlignment="Left"/>
                                <!-- 外部データソース(最新の実数値を確認) -->
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <TextBlock Text="リンク:" Style="{StaticResource Sub}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <ItemsControl ItemsSource="{Binding ReferenceLinks}">
                                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Content="{Binding Name}" Margin="0,0,6,4" Padding="8,3" FontSize="11"
                                                        ToolTip="{Binding Url}"
                                                        Command="{Binding DataContext.OpenLinkCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                                <Button Content="IRリンク" Command="{Binding OpenIrCommand}" Margin="0,0,6,0"
                                        Visibility="{Binding SelectedStock.IRUrl, Converter={StaticResource NotEmptyVis}}"/>
                                <Button Content="比較に追加" Command="{Binding AddToComparisonCommand}" Margin="0,0,6,0"/>
                                <Button Content="スクリーニング" Command="{Binding ShowScreeningCommand}" Margin="0,0,6,0"/>
                                <Button Content="銘柄比較" Command="{Binding ShowComparisonCommand}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- ===== 指標カード ===== -->
                    <WrapPanel Margin="0,4">
                        <Border Style="{StaticResource MetricCard}"><StackPanel><TextBlock Text="株価" Style="{StaticResource CardLabel}"/><TextBlock Text="{Binding SelectedStock.Price, StringFormat=N0}" Style="{StaticResource CardValue}"/></StackPanel></Border>
                        <Border Style="{StaticResource MetricCard}"><StackPanel><TextBlock Text="時価総額(百万)" Style="{StaticResource CardLabel}"/><TextBlock Text="{Binding SelectedStock.MarketCap, StringFormat=N0}" Style="{StaticResource CardValue}" FontSize="16"/></StackPanel></Border>
                        <Border Style="{StaticResource MetricCard}"><StackPanel><TextBlock Text="PER" Style="{StaticResource CardLabel}"/><TextBlock Text="{Binding SelectedStock.PER, StringFormat=0.0倍}" Style="{StaticResource CardValue}"/></StackPanel></Border>
                        <Border Style="{StaticResource MetricCard}"><StackPanel><TextBlock Text="PBR" Style="{StaticResource CardLabel}"/><TextBlock Text="{Binding SelectedStock.PBR, StringFormat=0.00倍}" Style="{StaticResource CardValue}"/></StackPanel></Border>
                        <Border Style="{StaticResource MetricCard}"><StackPanel><TextBlock Text="ROE" Style="{StaticResource CardLabel}"/><TextBlock Text="{Binding SelectedStock.ROE, StringFormat={}{0:0.0}%}" Style="{StaticResource CardValue}"/></StackPanel></Border>
                        <Border Style="{StaticResource MetricCard}"><StackPanel><TextBlock Text="MIX係数" Style="{StaticResource CardLabel}"/><TextBlock Text="{Binding SelectedStock.MixFactor, StringFormat=0.0}" Style="{StaticResource CardValue}"/></StackPanel></Border>
                        <Border Style="{StaticResource MetricCard}"><StackPanel><TextBlock Text="自己資本比率" Style="{StaticResource CardLabel}"/><TextBlock Text="{Binding SelectedStock.EquityRatio, StringFormat={}{0:0.0}%}" Style="{StaticResource CardValue}"/></StackPanel></Border>
                        <Border Style="{StaticResource MetricCard}"><StackPanel><TextBlock Text="配当利回り" Style="{StaticResource CardLabel}"/><TextBlock Text="{Binding SelectedStock.DividendYield, StringFormat={}{0:0.00}%}" Style="{StaticResource CardValue}"/></StackPanel></Border>
                        <Border Style="{StaticResource MetricCard}"><StackPanel><TextBlock Text="配当性向" Style="{StaticResource CardLabel}"/><TextBlock Text="{Binding SelectedStock.PayoutRatio, StringFormat={}{0:0.0}%}" Style="{StaticResource CardValue}"/></StackPanel></Border>
                        <Border Style="{StaticResource MetricCard}">
                            <StackPanel>
                                <TextBlock Text="総合評価" Style="{StaticResource CardLabel}"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding SelectedStock.OverallGrade}" Style="{StaticResource CardValue}" FontSize="26"
                                               Foreground="{Binding SelectedStock.OverallScore, Converter={StaticResource ScoreSolid}}"/>
                                    <TextBlock Text="{Binding SelectedStock.OverallScore, StringFormat=' ({0:0})'}" VerticalAlignment="Bottom" Margin="2,0,0,6"
                                               Foreground="{StaticResource SubTextBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource MetricCard}"><StackPanel><TextBlock Text="長期適性スコア" Style="{StaticResource CardLabel}"/><TextBlock Text="{Binding SelectedStock.LongTermScore, StringFormat=0}" Style="{StaticResource CardValue}" Foreground="{Binding SelectedStock.LongTermScore, Converter={StaticResource ScoreSolid}}"/></StackPanel></Border>
                        <Border Style="{StaticResource MetricCard}"><StackPanel><TextBlock Text="再評価期待スコア" Style="{StaticResource CardLabel}"/><TextBlock Text="{Binding SelectedStock.RevaluationScore, StringFormat=0}" Style="{StaticResource CardValue}" Foreground="{Binding SelectedStock.RevaluationScore, Converter={StaticResource ScoreSolid}}"/></StackPanel></Border>
                        <!-- バフェットスコア(強調) -->
                        <Border Style="{StaticResource MetricCard}" BorderThickness="2" BorderBrush="#FFB300" Background="#3A2F12">
                            <StackPanel><TextBlock Text="バフェットスコア" Style="{StaticResource CardLabel}" Foreground="#FFD54F"/>
                                <TextBlock Text="{Binding SelectedStock.BuffettScore, StringFormat=0}" Style="{StaticResource CardValue}" FontSize="24" Foreground="#FFD54F"/></StackPanel>
                        </Border>
                        <Border Style="{StaticResource MetricCard}"><StackPanel><TextBlock Text="買いたい度スコア" Style="{StaticResource CardLabel}"/><TextBlock Text="{Binding SelectedStock.WantToBuyScore, StringFormat=0}" Style="{StaticResource CardValue}" Foreground="{Binding SelectedStock.WantToBuyScore, Converter={StaticResource ScoreSolid}}"/></StackPanel></Border>
                        <Border Style="{StaticResource MetricCard}"><StackPanel><TextBlock Text="総合判定" Style="{StaticResource CardLabel}"/><TextBlock Text="{Binding SelectedStock.JudgementText}" Style="{StaticResource CardValue}" FontSize="13" TextWrapping="Wrap"/></StackPanel></Border>
                    </WrapPanel>

                    <!-- ===== グラフ ===== -->
                    <TextBlock Text="チャート" Style="{StaticResource H2}" Margin="6,8,0,0"/>
                    <ItemsControl ItemsSource="{Binding Charts}">
                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                    </ItemsControl>

                    <!-- ===== 下段: レーダー / バフェットチェック / 株主優待 / メモ ===== -->
                    <WrapPanel Margin="0,4">

                        <!-- スコアレーダー -->
                        <Border Style="{StaticResource Card}" Width="300" VerticalAlignment="Top">
                            <StackPanel>
                                <TextBlock Text="スコアレーダー" Style="{StaticResource H2}" FontSize="13" Margin="0,0,0,6"/>
                                <ItemsControl ItemsSource="{Binding Radar}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,3">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="56"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="52"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Label}" Style="{StaticResource Sub}"/>
                                                <Border Grid.Column="1" Background="#12161B" CornerRadius="3" Height="14">
                                                    <Border HorizontalAlignment="Left" Width="{Binding BarWidth}" CornerRadius="3"
                                                            Background="{Binding Color, Converter={StaticResource StrBrush}}"/>
                                                </Border>
                                                <TextBlock Grid.Column="2" TextAlignment="Right" Style="{StaticResource Sub}">
                                                    <Run Text="{Binding Grade, Mode=OneWay}" FontWeight="Bold"/><Run Text="{Binding Score, StringFormat=' {0:0}', Mode=OneWay}"/>
                                                </TextBlock>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- バフェットチェック -->
                        <Border Style="{StaticResource Card}" Width="380" VerticalAlignment="Top">
                            <StackPanel>
                                <TextBlock Text="バフェットチェック (はい/いいえ/不明)" Style="{StaticResource H2}" FontSize="13" Margin="0,0,0,6"/>
                                <ItemsControl ItemsSource="{Binding BuffettItems}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="84"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Label}" TextWrapping="Wrap" FontSize="11"/>
                                                <ComboBox Grid.Column="1" Height="24"
                                                          ItemsSource="{Binding DataContext.YesNoOptions, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                          SelectedItem="{Binding Answer, Mode=TwoWay}">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Converter={StaticResource YesNo}}"/>
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="※ チェックはバフェットスコアに反映されます。" Style="{StaticResource Sub}" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- 株主優待 -->
                        <Border Style="{StaticResource Card}" Width="320" VerticalAlignment="Top">
                            <StackPanel>
                                <TextBlock Text="株主優待・株主還元" Style="{StaticResource H2}" FontSize="13" Margin="0,0,0,6"/>
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="110"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
                                        <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="株主優待" Style="{StaticResource Sub}"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedStock.HasShareholderBenefit, Converter={StaticResource BoolFlag}}" Foreground="{Binding SelectedStock.HasShareholderBenefit, Converter={StaticResource FlagBrush}}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="優待利回り" Style="{StaticResource Sub}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedStock.BenefitYield, StringFormat={}{0:0.00}%}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="配当利回り" Style="{StaticResource Sub}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedStock.DividendYield, StringFormat={}{0:0.00}%}"/>
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="総合利回り" Style="{StaticResource Sub}"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedStock.TotalYield, StringFormat={}{0:0.00}%}" FontWeight="Bold"/>
                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="必要株数" Style="{StaticResource Sub}"/>
                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SelectedStock.RequiredSharesForBenefit, StringFormat=N0株}"/>
                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="優待価値" Style="{StaticResource Sub}"/>
                                    <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding SelectedStock.BenefitValue, StringFormat=N0円}"/>
                                    <TextBlock Grid.Row="6" Grid.Column="0" Text="権利確定月" Style="{StaticResource Sub}"/>
                                    <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding SelectedStock.BenefitRightsMonth}"/>
                                    <TextBlock Grid.Row="7" Grid.Column="0" Text="長期保有優遇" Style="{StaticResource Sub}"/>
                                    <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding SelectedStock.HasLongTermBenefit, Converter={StaticResource BoolFlag}, ConverterParameter=long}" Foreground="{Binding SelectedStock.HasLongTermBenefit, Converter={StaticResource FlagBrush}}"/>
                                    <TextBlock Grid.Row="8" Grid.Column="0" Text="長期保有条件" Style="{StaticResource Sub}"/>
                                    <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding SelectedStock.LongTermBenefitCondition}" TextWrapping="Wrap"/>
                                </Grid>
                                <TextBlock Text="優待内容" Style="{StaticResource Sub}" Margin="0,6,0,0"/>
                                <TextBlock Text="{Binding SelectedStock.BenefitContent}" TextWrapping="Wrap"/>
                                <TextBlock Text="優待廃止リスク" Style="{StaticResource Sub}" Margin="0,6,0,0"/>
                                <TextBlock Text="{Binding SelectedStock.BenefitRiskMemo}" TextWrapping="Wrap" Foreground="#FFB74D"/>
                            </StackPanel>
                        </Border>

                        <!-- メモ -->
                        <Border Style="{StaticResource Card}" Width="420" VerticalAlignment="Top">
                            <StackPanel>
                                <TextBlock Text="銘柄メモ" Style="{StaticResource H2}" FontSize="13" Margin="0,0,0,6"/>

                                <TextBlock Text="現在の分類" Style="{StaticResource FieldLabel}"/>
                                <ComboBox ItemsSource="{Binding ClassificationOptions}" SelectedItem="{Binding SelectedStock.Memo.Classification, Mode=TwoWay}"/>

                                <TextBlock Text="自分の興味 (0-100)" Style="{StaticResource FieldLabel}"/>
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Right" Width="34" TextAlignment="Right" Text="{Binding SelectedStock.UserInterest, StringFormat=0}"/>
                                    <Slider Minimum="0" Maximum="100" Value="{Binding SelectedStock.UserInterest, Mode=TwoWay}"/>
                                </DockPanel>

                                <TextBlock Text="この銘柄を見つけた理由" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding SelectedStock.Memo.DiscoveryReason, Mode=TwoWay}" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="36"/>
                                <TextBlock Text="気になった数値" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding SelectedStock.Memo.InterestingNumbers, Mode=TwoWay}" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="36"/>
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="8"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="良い点" Style="{StaticResource FieldLabel}"/>
                                        <TextBox Text="{Binding SelectedStock.Memo.GoodPoints, Mode=TwoWay}" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="36"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="悪い点" Style="{StaticResource FieldLabel}"/>
                                        <TextBox Text="{Binding SelectedStock.Memo.BadPoints, Mode=TwoWay}" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="36"/>
                                    </StackPanel>
                                </Grid>
                                <TextBlock Text="長期優良株としての評価" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding SelectedStock.Memo.LongTermEvaluation, Mode=TwoWay}" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="36"/>
                                <TextBlock Text="再評価候補としての評価" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding SelectedStock.Memo.RevaluationEvaluation, Mode=TwoWay}" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="36"/>
                                <TextBlock Text="第二のキオクシア候補として見る理由" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding SelectedStock.Memo.KioxiaReason, Mode=TwoWay}" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="36"/>
                                <TextBlock Text="次に確認する情報" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding SelectedStock.Memo.NextToCheck, Mode=TwoWay}" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="36"/>

                                <Button Content="チェック・メモを保存してスコア再計算" Command="{Binding ApplyCommand}" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>
                    </WrapPanel>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
