<Window x:Class="DStockAnalysis.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:DStockAnalysis.ViewModels"
        Title="DStockAnalysis - 投資銘柄探索ダッシュボード"
        Width="1600" Height="900" MinWidth="1200" MinHeight="720"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="{StaticResource BgBrush}">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <DockPanel LastChildFill="True">

        <!-- ===== 上部ヘッダー ===== -->
        <Border DockPanel.Dock="Top" Background="#161A1F" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="14,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- ロゴ/タイトル -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,24,0">
                    <Border Width="30" Height="30" CornerRadius="6" Background="{StaticResource AccentBrush}" Margin="0,0,8,0">
                        <TextBlock Text="D" FontWeight="Bold" FontSize="18" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="DStockAnalysis" Style="{StaticResource H2}"/>
                        <TextBlock Text="投資研究ダッシュボード" Style="{StaticResource Sub}"/>
                    </StackPanel>
                </StackPanel>

                <!-- 画面切替ボタン -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="銘柄スクリーニング" Command="{Binding ShowScreeningCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveScreen}" Value="Screening">
                                        <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="個別銘柄分析" Command="{Binding ShowAnalysisCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveScreen}" Value="Analysis">
                                        <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="銘柄比較" Command="{Binding ShowComparisonCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveScreen}" Value="Comparison">
                                        <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <!-- 右上: データ更新日・操作 -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding DataUpdatedText}" Style="{StaticResource Sub}" Margin="0,0,16,0" VerticalAlignment="Center"/>
                    <Button Content="全銘柄更新(JPX)" Command="{Binding UpdateMasterCommand}" Margin="0,0,6,0"
                            ToolTip="日本取引所グループの上場銘柄一覧(毎月更新)を再ダウンロードします"/>
                    <Button Content="CSV取込" Command="{Binding ImportCsvCommand}" Margin="0,0,6,0"
                            ToolTip="銘柄コードで照合し、実データ指標を上書き取込します"/>
                    <Button Content="サンプル" Command="{Binding LoadSampleCommand}" Margin="0,0,6,0"/>
                    <Button Content="再計算" Command="{Binding RecalculateCommand}" Margin="0,0,6,0"/>
                    <Button Content="保存" Command="{Binding SaveCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== ステータスバー ===== -->
        <Border DockPanel.Dock="Bottom" Background="#13171C" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <Grid Margin="14,5">
                <TextBlock Text="{Binding StatusText}" Style="{StaticResource Sub}" HorizontalAlignment="Left"/>
                <TextBlock Text="{Binding IndicatorNotice}" Style="{StaticResource Sub}" HorizontalAlignment="Right"
                           Foreground="#FFB74D"/>
            </Grid>
        </Border>

        <!-- ===== メイン領域 ===== -->
        <ContentControl Content="{Binding CurrentViewModel}" Margin="6"/>
    </DockPanel>
</Window>
